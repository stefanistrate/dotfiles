{
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "[svg]": {
        "editor.defaultFormatter": "jock.svg"
    },
    "chat.disableAIFeatures": true,
    "claudeCode.initialPermissionMode": "acceptEdits",
    "claudeCode.preferredLocation": "panel",
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.maxComputationTime": 15000,
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": true,
    "editor.rulers": [
        88
    ],
    "explorer.confirmDelete": false,
    "files.associations": {
        "*.borg": "properties"
    },
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 60000,
    "files.insertFinalNewline": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.detectSubmodules": false,
    "git.enableCommitSigning": true,
    "githubPullRequests.createOnPublishBranch": "never",
    "isort.check": true,
    "jupyter.askForKernelRestart": false,
    "jupyter.notebookFileRoot": "${workspaceFolder}",
    "jupyter.widgetScriptSources": [
        "jsdelivr.com",
        "unpkg.com"
    ],
    "markdown.extension.math.enabled": false,
    "markdown.preview.fontSize": 16,
    "markdownlint.config": {
        "MD013": false,
        "MD024": {
            "siblings_only": true
        },
        "MD033": {
            "allowed_elements": [
                "br"
            ]
        }
    },
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "projectManager.git.baseFolders": [
        "~/work"
    ],
    "projectManager.git.maxDepthRecursion": 1,
    "python.analysis.useLibraryCodeForTypes": false,
    "python.languageServer": "Jedi",
    "python.pythonPath": "python3",
    "redhat.telemetry.enabled": false,
    "security.workspace.trust.untrustedFiles": "open",
    "telemetry.telemetryLevel": "off",
    "terminal.integrated.drawBoldTextInBrightColors": false,
    "terminal.integrated.fontFamily": "'Droid Sans Mono Dotted for Powerline', monospace",
    "ty.inlayHints.callArgumentNames": false,
    "ty.inlayHints.variableTypes": false,
    "update.mode": "start",
    "workbench.colorTheme": "Solarized Autumn",
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter-notebook"
    },
    "workbench.experimental.modernUI": true,
    "workbench.iconTheme": "material-icon-theme",
    "workbench.sideBar.location": "right",
    "workbench.startupEditor": "none"
}
